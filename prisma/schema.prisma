generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Company {
  id           String        @id @default(cuid())
  name         String        @unique
  applications Application[]
  createdAt    DateTime      @default(now())
}

model ResumeVersion {
  id             String          @id @default(cuid())
  label          String
  notes          String?
  fileUrl        String?
  fileName       String?
  isGolden       Boolean         @default(false)
  structuredData Json?
  applications   Application[]
  parents        ResumeLineage[] @relation("Child")
  children       ResumeLineage[] @relation("Parent")
  createdAt      DateTime        @default(now())
}

model Application {
  id             String        @id @default(cuid())
  company        Company       @relation(fields: [companyId], references: [id])
  companyId      String
  resume         ResumeVersion @relation(fields: [resumeId], references: [id])
  resumeId       String
  roleTitle      String
  jobDescription String        @db.Text
  postingUrl     String?
  emailUsed      String
  appliedDate    DateTime      @default(now())
  status         Status        @default(APPLIED)
  notes          String?       @db.Text
  createdAt      DateTime      @default(now())
}

model ResumeLineage {
  resumeId       String
  parentResumeId String
  relationType   RelationType
  notes          String?       @db.Text
  createdAt      DateTime      @default(now())
  resume         ResumeVersion @relation("Child", fields: [resumeId], references: [id])
  parent         ResumeVersion @relation("Parent", fields: [parentResumeId], references: [id])

  @@id([resumeId, parentResumeId])
}

enum RelationType {
  BASED_ON
  BORROWED_BULLET
  MERGED_FROM
}

enum Status {
  APPLIED
  PHONE_SCREEN
  INTERVIEW
  OFFER
  REJECTED
  GHOSTED
}